        ".opencode/workflow-state.json",
        ".opencode/work-items/",
        ".opencode/workflow-state.js",
        "hooks/",
        "agents/",
        "skills/",
        "commands/",
        "context/",
        "docs/"
      ],
      "wrapperFacingMetadata": [
        "registry.json",
        ".opencode/install-manifest.json"
