{
  "model": "anthropic/claude-sonnet-4-5",
  "agents_dir": "agents",
  "skills_dir": "skills",
  "commands_dir": "commands",
  "kit": {
    "name": "OpenKit AI Software Factory",
    "version": "0.1.0",
    "entryAgent": "MasterOrchestrator",
    "productSurface": {
      "current": "repository-local-openkit-runtime",
      "emerging": "managed-opencode-wrapper",
