{
  "$schema": "https://opencode.ai/config.json",
  "kit": {
    "name": "OpenKit AI Software Factory",
    "version": "0.3.26",
    "entryAgent": "MasterOrchestrator"
  },
  "mcp": {
    "openkit": {
      "type": "local",
      "command": ["node", "bin/openkit-mcp.js"],
      "enabled": true,
      "environment": {
        "OPENKIT_PROJECT_ROOT": "{cwd}"
      }
    },
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@0.21.0"],
      "enabled": true
    }
  },
  "permission": {
    "npm": "allow",
    "task": "allow",
    "bash": "allow",
    "edit": "allow",
    "read": "allow",
    "write": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "skill": "allow",
    "lsp": "allow",
    "todoread": "allow",
    "todowrite": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "codesearch": "allow",
    "external_directory": "allow",
    "doom_loop": "allow",
    "rm": "ask",
    "rmdir": "ask",
    "unlink": "ask",
    "git status": "allow",
    "git log": "allow",
    "git diff": "allow",
    "git reset --hard": "ask",
    "git clean": "ask",
    "git restore": "ask",
    "git checkout": "ask",
    "git push --force": "ask",
    "git push --force-with-lease": "ask",
    "npm publish": "ask",
    "npm unpublish": "ask",
    "openkit release publish": "ask",
    "deploy": "ask",
    "release publish": "ask",
    "dropdb": "ask",
    "truncate": "ask",
    "db reset": "ask",
    "db wipe": "ask",
    "sudo": "ask",
    "chmod": "ask",
    "chown": "ask"
  },
  "commandPermissionPolicy": {
    "schema": "openkit/command-permission-policy@1",
    "version": 1,
    "intent": "default-allow-with-confirm-required-exceptions",
    "desiredDefaultAction": "allow",
    "projectionSupport": "degraded",
    "effectiveProjection": "explicit-permission-map-with-visible-degraded-status",
    "defaultActionSupport": "unverified",
    "unsupportedGranularityCount": 4
  },
  "instructions": [
    "AGENTS.md",
    "context/navigation.md",
    "context/core/tool-substitution-rules.md"
  ],
  "hooks": {
    "rulesInjector": {
      "always": [
        "Use OpenKit kit tools (available as openkit_* MCP tools) and OpenCode built-in tools (Read, Edit, Write, Glob, Grep) instead of OS-level commands (grep, cat, find, sed, awk) when operating on source code files. Bash calls for blocked commands will be rejected by the tool enforcement plugin."
      ],
      "byMode": {
        "quick": [
          "STRICT enforcement: All OS-level search/read/transform commands on code files are blocked. Use built-in tools exclusively. Prefer openkit_* MCP tools for semantic search, symbol lookup, and code navigation."
        ],
        "full": [
          "STRICT enforcement: All OS-level search/read/transform commands on code files are blocked. Use built-in tools exclusively. Prefer openkit_* MCP tools for semantic search, symbol lookup, and code navigation."
        ],
        "migration": [
          "MODERATE enforcement: OS-level commands generate warnings but are not blocked. Prefer built-in tools and openkit_* MCP tools when possible."
        ]
      }
    }
  }
}
