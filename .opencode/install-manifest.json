{
  "schema": "openkit/install-manifest@1",
  "manifestVersion": 1,
  "kit": {
    "name": "OpenKit AI Software Factory",
    "version": "0.1.0"
  },
  "registry": {
    "path": "registry.json",
    "schema": "openkit/component-registry@1",
    "registryVersion": 1
  },
  "installation": {
    "type": "checked-in-local-metadata",
    "activeProfile": "openkit-core",
    "installedAt": "repository-root",
    "managedRemotely": false,
    "mode": "additive-non-destructive",
    "wrapperReadiness": "emerging",
    "notes": "This manifest describes additive metadata checked into this repository. It does not fetch remote components, remove the repository-local runtime, or imply that the managed wrapper migration is already complete.",
    "repositoryInternalRuntime": ".opencode/opencode.json",
    "wrapperFacingMetadata": [
      "registry.json",
      ".opencode/install-manifest.json"
    ]
  },
  "migration": {
    "currentRuntimeManifest": ".opencode/opencode.json",
    "targetWrapperEntrypoint": "opencode.json",
    "status": "staged-not-complete",
    "notes": "The planned wrapper entrypoint is not checked in yet. Until it exists, repository operators should continue using the repository-local runtime surface."
  },
  "components": {
    "agents": "present",
    "skills": "present",
    "commands": "present",
    "artifacts": "present",
    "runtime": "present",
    "hooks": "present",
    "docs": "present"
  }
}
